{#- Jinja2 template for resume.yaml → Markdown.
    target_tag: the variant being built (e.g. "csharp", "python")
    all_variants: full list of variant tags (e.g. ["csharp", "python"])
    An entry/bullet with no x-tags is treated as common (shown in all variants).
    A bullet with no x-tags inherits its parent entry's tags.
    "backend" is a pass-through tag that appears in all variants.
-#}

{%- macro visible(node_tags, parent_tags=None) -%}
  {#- Returns "True" if this node should appear in the target variant.
      "backend" is a pass-through ONLY when no other variant-specific tag is present.
      e.g. [backend] → all variants; [backend, csharp] → csharp only. -#}
  {%- set effective = node_tags if node_tags is not none else (parent_tags if parent_tags else ["common"]) -%}
  {%- set _other = all_variants | reject("equalto", target_tag) | list -%}
  {%- set _restricted = effective | select("in", _other) | list | length > 0 -%}
  {{ target_tag in effective or "common" in effective or ("backend" in effective and not _restricted) }}
{%- endmacro -%}

# {{ data.meta.name }}

**{{ data.meta.title }}**

{{ data.meta.email }} | {{ data.meta.phone }} | {{ data.meta.location }} | {{ data.meta.linkedin }}

*{{ data.meta.open_to }}*

---

## Summary

{{ data.summary }}

---

## Skills

{% for category, items in data.skills.items() %}
**{{ category | title }}:** {{ items | join(", ") }}

{% endfor %}

---

## Experience

{% for job in data.experience %}
{%- set job_tags = job.get("x-tags", ["common"]) %}
{%- if not job.get("x-hidden") and visible(job_tags) | trim == "True" %}

### {{ job.role }} — {{ job.company }}

*{{ job.period }}*{% if job.location %} | {{ job.location }}{% endif %}

{% if job.projects %}
{% for project in job.projects %}
{%- set proj_tags = project.get("x-tags", job_tags) %}
{%- if visible(proj_tags) | trim == "True" %}
**{{ project.name }}** *({{ project.period }})*

{% for bullet in project.get("bullets", []) %}
{%- set bullet_tags = bullet.get("x-tags", proj_tags) %}
{%- if visible(bullet_tags) | trim == "True" %}
- {{ bullet.text }}
{% endif %}
{%- endfor %}
{% endif %}
{%- endfor %}
{% else %}
{% for bullet in job.get("bullets", []) %}
{%- set bullet_tags = bullet.get("x-tags", job_tags) %}
{%- if visible(bullet_tags) | trim == "True" %}
- {{ bullet.text }}
{% endif %}
{%- endfor %}
{% endif %}
{% endif %}
{%- endfor %}

